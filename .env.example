DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=replace-for-non-local-environments
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=Conta Saga <no-reply@localhost>
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=false
DJANGO_EMAIL_USE_SSL=false
DJANGO_EMAIL_TIMEOUT=10
DJANGO_LOG_LEVEL=INFO

# Shared database-backed login throttling.
LOGIN_RATE_LIMIT_ACCOUNT_ATTEMPTS=5
LOGIN_RATE_LIMIT_IP_ATTEMPTS=25
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=3
PASSWORD_RESET_RATE_LIMIT_IP_ATTEMPTS=20
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=900

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=conta_saga
POSTGRES_WEB_USER=web_app
POSTGRES_WEB_PASSWORD=change-me
POSTGRES_PRIVILEGED_USER=worker
POSTGRES_PRIVILEGED_PASSWORD=change-me
POSTGRES_MIGRATION_USER=migrare
POSTGRES_MIGRATION_PASSWORD=change-me

# Local development stores objects under .local-storage (no Docker/cloud needed).
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_DOWNLOAD_URL_TTL=300
DOCUMENT_LOCAL_STORAGE_ROOT=.local-storage

# Production Cloudflare R2 configuration (DOCUMENT_STORAGE_BACKEND=r2).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Production-only values (use config.settings.prod / config.settings.admin_prod).
RELEASE_ENVIRONMENT=development
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com,https://admin.example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
# Enable only when the application is behind a trusted TLS-terminating proxy.
DJANGO_TRUST_X_FORWARDED_PROTO=false
# Set only if the trusted proxy overwrites this header.
DJANGO_CLIENT_IP_HEADER=
POSTGRES_CONN_MAX_AGE=60
