{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "python manage.py collectstatic --noinput --settings=config.settings.prod"
  },
  "deploy": {
    "preDeployCommand": [
      "python manage.py migrate --settings=config.settings.migration"
    ],
    "startCommand": "gunicorn --bind 0.0.0.0:${PORT:-8000} --workers 2 --threads 2 --timeout 120 --access-logfile - --error-logfile - config.wsgi:application",
    "healthcheckPath": "/health/ready/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
