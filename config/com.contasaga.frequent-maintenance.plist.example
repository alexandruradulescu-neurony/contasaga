<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.contasaga.frequent-maintenance</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_DIR__/.venv/bin/python</string>
        <string>__PROJECT_DIR__/manage.py</string>
        <string>run_scheduled_maintenance</string>
        <string>frequent</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/.local-logs/frequent-maintenance.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/.local-logs/frequent-maintenance.err.log</string>
</dict>
</plist>
